---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getSiteConfig } from '../../lib/content';
import { localizePath } from '../../lib/site';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
const posts = (await getCollection('blog', ({ data }) => data.lang === locale && !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const formatDate = (date: Date) =>
	date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout locale={locale} alternatePath="/zh/blog/" title={`Blog | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Blog"
			title="Research thoughts, notes, and reflective writing"
			intro="This section is reserved for ideas, direction-setting, reading notes, and short technical reflections."
		/>
		{
			posts.length > 0 ? (
				<div class="cards-grid two">
					{posts.map((post) => (
						<EntryCard
							title={post.data.title}
							summary={post.data.summary}
							meta={formatDate(post.data.date)}
							tags={post.data.tags}
							href={localizePath(locale, `blog/${post.data.routeSlug}`)}
							ctaLabel="Read more"
						/>
					))}
				</div>
			) : (
				<section class="surface-card empty-state stack gap-4">
					<span class="meta-chip warm">No posts yet</span>
					<h2>Writing has not started yet</h2>
					<p class="lede">
						This page is intentionally empty for now. Future posts can hold research thoughts,
						reading notes, and short technical reflections.
					</p>
				</section>
			)
		}
	</main>
</BaseLayout>

<style>
	.empty-state {
		padding: 1.5rem;
		max-width: 48rem;
	}
</style>
