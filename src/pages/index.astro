---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TimelineCard from '../components/TimelineCard.astro';
import { getSiteConfig } from '../lib/content';
import { localizePath } from '../lib/site';

const locale = 'en' as const;
const site = await getSiteConfig(locale);

const projects = (await getCollection('projects', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const activeProjects = projects.filter((project) => project.data.status !== 'completed');
const featuredProjects = activeProjects.filter((project) =>
	site.featuredProjects.includes(project.data.translationKey),
);
const timeline = (await getCollection('timeline', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const posts = (await getCollection('blog', ({ data }) => data.lang === locale && !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const manuals = (await getCollection('manuals', ({ data }) => data.lang === locale)).sort(
	(a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);

const heroKeywords = site.hero.keywords.slice(0, 4);
const currentThreads = activeProjects
	.map((project) => project.data.title)
	.slice(0, 3)
	.join(' / ');

const formatDate = (date: Date) =>
	date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	locale={locale}
	alternatePath="/zh/"
	title={`${site.name} | ${site.title}`}
	description={site.tagline}
>
	<main class="wrapper page-main stack gap-20">
		<section class="home-hero">
			<div class="hero-copy stack gap-6">
				<div class="stack gap-4">
					<span class="eyebrow">Power Electronics / Medium Voltage</span>
					<h1>{site.hero.headline}</h1>
					<p class="hero-summary">{site.tagline}</p>
					<p class="hero-note">{site.hero.subheadline}</p>
				</div>

				<ul class="tag-list">
					{heroKeywords.map((keyword) => <li class="tag">{keyword}</li>)}
				</ul>

				<div class="hero-actions">
					<a class="button-link" href={localizePath(locale, 'current-focus')}>View current focus</a>
					<a class="button-link secondary" href={localizePath(locale, 'projects')}>Open projects</a>
				</div>

				<div class="surface-card profile-band">
					<div class="profile-item">
						<span class="mono">ROLE</span>
						<p>{site.title}</p>
					</div>
					<div class="profile-item">
						<span class="mono">BASE</span>
						<p>{site.location}</p>
					</div>
					<div class="profile-item">
						<span class="mono">CONTACT</span>
						<p>{site.email}</p>
					</div>
				</div>
			</div>

			<div class="surface-card hero-summary-card">
				<div class="hero-topology" aria-hidden="true">
					<div class="hero-trace hero-trace-a" />
					<div class="hero-trace hero-trace-b" />
					<div class="hero-trace hero-trace-c" />
					<div class="hero-node hero-node-a" />
					<div class="hero-node hero-node-b" />
					<div class="hero-node hero-node-c" />
					<div class="hero-glow hero-glow-a" />
					<div class="hero-glow hero-glow-b" />
				</div>

				<div class="summary-shell stack gap-5">
					<div class="stack gap-3">
						<span class="mono muted">RESEARCH SIGNAL</span>
						<h2>{site.currentFocus.theme}</h2>
						<p>{site.currentFocus.importance}</p>
					</div>

					<div class="summary-meta">
						<div class="summary-chip">
							<span class="signal-label">Active Threads</span>
							<p>{currentThreads}</p>
						</div>
						<div class="summary-chip">
							<span class="signal-label">Current Mode</span>
							<p>Ongoing research, active experiments, and system-focused engineering.</p>
						</div>
					</div>
				</div>

				<div class="quick-grid">
					{
						site.hero.quickFacts.map((fact) => (
							<div class="quick-card">
								<span class="mono muted">{fact.label}</span>
								<h3>{fact.value}</h3>
								<p>{fact.detail}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Current Focus"
				title="The current research direction at a glance"
				intro="A quick read should make the present research theme, its relevance, and the active threads obvious."
			/>
			<div class="cards-grid three">
				<div class="surface-card mini-card">
					<span class="meta-chip warm">Research theme</span>
					<p>{site.currentFocus.theme}</p>
				</div>
				<div class="surface-card mini-card">
					<span class="meta-chip">Why it matters</span>
					<p>{site.currentFocus.importance}</p>
				</div>
				<div class="surface-card mini-card">
					<span class="meta-chip">Active threads</span>
					<p>{currentThreads}</p>
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Featured Projects"
				title="Projects that define the current direction"
				intro="These are the systems and research threads shaping the current medium-voltage focus."
			/>
			<div class="cards-grid three">
				{featuredProjects.map((project) => <ProjectCard project={project} locale={locale} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Journey"
				title="A concise timeline from hardware foundations to medium-voltage research"
				intro="The timeline shows how early converter practice, master's research, and PhD work built on each other."
			/>
			<div class="stack gap-6">
				{timeline.map((entry) => <TimelineCard entry={entry} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Writing and Manuals"
				title="Notes and manuals will start from empty state"
				intro="These sections are intentionally blank for now, so the site reflects your real content status instead of demo placeholders."
			/>
			<div class="cards-grid two">
				<div class="entry-column stack gap-4">
					<h3>Latest writing</h3>
					{
						posts.length > 0 ? (
							posts.slice(0, 2).map((post) => (
								<EntryCard
									title={post.data.title}
									summary={post.data.summary}
									meta={formatDate(post.data.date)}
									tags={post.data.tags}
									href={localizePath(locale, `blog/${post.data.routeSlug}`)}
									ctaLabel="Read more"
								/>
							))
						) : (
							<div class="surface-card empty-entry">
								<span class="meta-chip warm">Empty for now</span>
								<p>No blog posts have been published yet.</p>
							</div>
						)
					}
				</div>
				<div class="entry-column stack gap-4">
					<h3>Lab manuals</h3>
					{
						manuals.length > 0 ? (
							manuals.slice(0, 2).map((manual) => (
								<EntryCard
									title={manual.data.title}
									summary={manual.data.summary}
									meta={`${manual.data.tool_or_platform} · ${formatDate(manual.data.updatedAt)}`}
									tags={manual.data.tags}
									href={localizePath(locale, `manuals/${manual.data.routeSlug}`)}
									ctaLabel="Open manual"
								/>
							))
						) : (
							<div class="surface-card empty-entry">
								<span class="meta-chip warm">Empty for now</span>
								<p>No manuals have been published yet.</p>
							</div>
						)
					}
				</div>
			</div>
		</section>

		<section class="surface-card contact-panel">
			<div class="stack gap-4">
				<span class="eyebrow">Contact</span>
				<h2>{site.contact.title}</h2>
				<p class="lede">{site.contact.text}</p>
			</div>
			<div class="hero-actions">
				<a class="button-link" href={`mailto:${site.email}`}>Email me</a>
				<a class="button-link secondary" href={localizePath(locale, 'publications')}>View publications</a>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-hero {
		position: relative;
		display: grid;
		gap: 2rem;
		align-items: start;
	}

	.hero-summary {
		max-width: 40rem;
		font-size: 1.05rem;
		color: var(--text-body);
	}

	.hero-note {
		max-width: 38rem;
		color: var(--text-muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.profile-band,
	.mini-card,
	.contact-panel,
	.hero-summary-card {
		padding: 1.5rem;
	}

	.profile-band {
		display: grid;
		gap: 1rem;
	}

	.profile-item span,
	.signal-label {
		color: var(--accent-cyan);
		font-size: var(--text-sm);
		letter-spacing: 0.12em;
	}

	.profile-item p {
		margin-top: 0.35rem;
	}

	.hero-summary-card {
		position: relative;
		display: grid;
		gap: 1rem;
	}

	.hero-topology {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		opacity: 0.92;
	}

	.hero-trace,
	.hero-node,
	.hero-glow {
		position: absolute;
	}

	.hero-trace {
		block-size: 1px;
		background: linear-gradient(90deg, transparent, rgba(70, 182, 200, 0.4), transparent);
		box-shadow: 0 0 14px rgba(70, 182, 200, 0.14);
	}

	.hero-trace-a {
		inline-size: 18rem;
		top: 16%;
		right: -6%;
		transform: rotate(-16deg);
	}

	.hero-trace-b {
		inline-size: 14rem;
		top: 58%;
		right: 18%;
		transform: rotate(22deg);
		background: linear-gradient(90deg, transparent, rgba(215, 121, 57, 0.34), transparent);
		box-shadow: 0 0 14px rgba(215, 121, 57, 0.12);
	}

	.hero-trace-c {
		inline-size: 10rem;
		bottom: 18%;
		left: 42%;
		transform: rotate(-34deg);
	}

	.hero-node {
		inline-size: 0.45rem;
		block-size: 0.45rem;
		border-radius: 50%;
		background: rgba(70, 182, 200, 0.88);
		box-shadow: 0 0 0 0.2rem rgba(70, 182, 200, 0.08);
	}

	.hero-node-a {
		top: 18%;
		right: 18%;
	}

	.hero-node-b {
		top: 58%;
		right: 46%;
		background: rgba(215, 121, 57, 0.82);
		box-shadow: 0 0 0 0.22rem rgba(215, 121, 57, 0.08);
	}

	.hero-node-c {
		bottom: 22%;
		right: 12%;
	}

	.hero-glow {
		border-radius: 50%;
		filter: blur(18px);
	}

	.hero-glow-a {
		inline-size: 9rem;
		block-size: 9rem;
		top: -2rem;
		right: -1rem;
		background: radial-gradient(circle, rgba(70, 182, 200, 0.18), transparent 66%);
	}

	.hero-glow-b {
		inline-size: 8rem;
		block-size: 8rem;
		bottom: -2rem;
		right: 3rem;
		background: radial-gradient(circle, rgba(215, 121, 57, 0.14), transparent 66%);
	}

	.summary-shell,
	.quick-grid {
		position: relative;
		z-index: 1;
	}

	.summary-shell h2 {
		max-width: 28rem;
		font-size: clamp(1.55rem, 3vw, 2.2rem);
		line-height: 1.12;
	}

	.summary-shell p,
	.summary-chip p,
	.quick-card p,
	.mini-card p,
	.empty-entry {
		color: var(--text-muted);
	}

	.summary-meta,
	.quick-grid {
		display: grid;
		gap: 0.9rem;
	}

	.summary-chip,
	.quick-card {
		padding: 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(125, 148, 176, 0.12);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
			rgba(255, 255, 255, 0.02);
	}

	.summary-chip p,
	.quick-card h3 {
		margin-top: 0.45rem;
	}

	.quick-card h3 {
		font-size: 1.28rem;
	}

	.entry-column h3 {
		font-size: 1.22rem;
	}

	.empty-entry {
		padding: 1.1rem;
		display: grid;
		gap: 0.75rem;
	}

	.contact-panel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (max-width: 47.99em) {
		.hero-trace-a,
		.hero-trace-b,
		.hero-trace-c {
			opacity: 0.55;
		}
	}

	@media (min-width: 48em) {
		.profile-band,
		.summary-meta,
		.quick-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.profile-band .profile-item:last-child,
		.quick-grid > :nth-child(3) {
			grid-column: 1 / -1;
		}
	}

	@media (min-width: 68em) {
		.home-hero {
			grid-template-columns: minmax(0, 0.96fr) minmax(22rem, 1.08fr);
		}

		.profile-band {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.profile-band .profile-item:last-child {
			grid-column: auto;
		}

		.quick-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.quick-grid > :nth-child(3) {
			grid-column: auto;
		}

		.contact-panel {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
