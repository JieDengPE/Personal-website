---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getSiteConfig } from '../lib/content';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
const projects = site.currentFocus.projects;
---

<BaseLayout
	locale={locale}
	alternatePath="/zh/current-focus/"
	title={`Current Focus | ${site.name}`}
	description={site.currentFocus.importance}
>
	<main class="wrapper page-main stack gap-16">
		<SectionHeading
			eyebrow="Current Focus"
			title="What I am researching now and why it matters"
			intro="This page is intentionally simple: it should help a first-time visitor understand the active research theme, the major project threads, and the direction I am building toward."
		/>

		<section class="surface-card focus-overview">
			<div class="stack gap-4">
				<span class="meta-chip warm">Research theme</span>
				<h2>{site.currentFocus.theme}</h2>
				<p class="lede">{site.currentFocus.now}</p>
			</div>
			<ul class="tag-list">
				{site.researchAreas.map((area) => <li class="tag">{area}</li>)}
			</ul>
		</section>

		<section class="cards-grid three">
			{
				projects.map((project) => (
					<article class="surface-card project-brief stack gap-4">
						<div class="project-brief-meta">
							<span class="meta-chip warm">{project.status}</span>
						</div>
						<div class="stack gap-2">
							<h3>{project.title}</h3>
							<p>{project.summary}</p>
						</div>
					</article>
				))
			}
		</section>

		<section class="cards-grid two">
			<article class="surface-card focus-card stack gap-4">
				<span class="meta-chip">Why it matters</span>
				<p>{site.currentFocus.importance}</p>
			</article>
			<article class="surface-card focus-card stack gap-4">
				<span class="meta-chip">Near-term goals</span>
				<ul class="focus-list">
					{site.currentFocus.goals.map((item) => <li>{item}</li>)}
				</ul>
			</article>
		</section>
	</main>
</BaseLayout>

<style>
	.focus-overview,
	.project-brief,
	.focus-card {
		padding: 1.45rem;
	}

	.project-brief {
		min-height: 100%;
	}

	.project-brief p,
	.focus-card p {
		color: var(--text-muted);
	}

	.project-brief-meta {
		display: flex;
		justify-content: flex-start;
	}

	.focus-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.6rem;
	}
</style>
