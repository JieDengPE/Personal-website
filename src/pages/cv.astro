---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getSiteConfig } from '../lib/content';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
---

<BaseLayout locale={locale} alternatePath="/zh/cv/" title={`CV | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="CV / Contact"
			title="Profile, education, and collaboration overview"
			intro="This page is a concise public-facing summary and can later be paired with a downloadable PDF CV."
		/>

		<section class="cards-grid two">
			<article class="surface-card cv-card stack gap-4">
				<h3>Profile</h3>
				<p>{site.cv.profile}</p>
				<ul class="tag-list">
					{site.researchAreas.map((area) => <li class="tag">{area}</li>)}
				</ul>
			</article>
			<article class="surface-card cv-card stack gap-4">
				<h3>Contact</h3>
				<p>{site.contact.text}</p>
				<p><a class="text-link" href={`mailto:${site.email}`}>{site.email}</a></p>
				<div class="stack gap-2">
					{site.socialLinks.map((link) => <a class="text-link" href={link.href}>{link.label}</a>)}
				</div>
			</article>
		</section>

		<section class="cards-grid two">
			<article class="surface-card cv-card stack gap-4">
				<h3>Education</h3>
				<div class="stack gap-4">
					{
						site.cv.education.map((entry) => (
							<div class="stack gap-2">
								<p class="mono muted">{entry.period}</p>
								<h4>{entry.stage}</h4>
								<p>{entry.institution}</p>
								<p>{entry.focus}</p>
							</div>
						))
					}
				</div>
			</article>
			<article class="surface-card cv-card stack gap-4">
				<h3>Strengths and collaboration</h3>
				<ul class="focus-list">
					{site.cv.strengths.map((item) => <li>{item}</li>)}
				</ul>
				<ul class="focus-list">
					{site.cv.collaboration.map((item) => <li>{item}</li>)}
				</ul>
			</article>
		</section>
	</main>
</BaseLayout>

<style>
	.cv-card {
		padding: 1.25rem;
	}

	.focus-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.55rem;
	}
</style>
