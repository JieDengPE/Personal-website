---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getSiteConfig } from '../../lib/content';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
const projects = (await getCollection('projects', ({ data }) => data.lang === locale))
	.filter((project) => project.data.status === 'completed')
	.sort((a, b) => a.data.order - b.data.order);
const publications = await getCollection('publications', ({ data }) => data.lang === locale);
---

<BaseLayout locale={locale} alternatePath="/zh/projects/" title={`Projects | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Projects"
			title="Completed projects and research outputs"
			intro="This page works as an archive of completed or publication-backed work. It includes finished engineering projects, mature research efforts, and related publications when available."
		/>
		<div class="cards-grid three">
			{
				projects.map((project) => {
					const relatedPublications = publications.filter((publication) =>
						project.data.relatedPublications.includes(publication.data.translationKey),
					);

					return (
						<ProjectCard
							project={project}
							locale={locale}
							relatedPublications={relatedPublications}
						/>
					);
				})
			}
		</div>
	</main>
</BaseLayout>
