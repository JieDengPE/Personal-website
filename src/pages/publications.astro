---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getSiteConfig } from '../lib/content';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
const entries = (await getCollection('publications', ({ data }) => data.lang === locale)).sort(
	(a, b) => b.data.year - a.data.year,
);
---

<BaseLayout locale={locale} alternatePath="/zh/publications/" title={`Publications | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Publications"
			title="Papers, posters, talks, and technical outputs"
			intro="This section is intentionally flexible so it can hold conference papers, posters, internal talks, workshop materials, or patents."
		/>
		<div class="stack gap-6">
			{
				entries.map((entry) => (
					<article class="surface-card pub-card">
						<div class="stack gap-4">
							<div class="pub-meta">
								<span class="meta-chip warm">{entry.data.type}</span>
								<span class="meta-chip">{String(entry.data.year)}</span>
							</div>
							<div class="stack gap-2">
								<h3>{entry.data.title}</h3>
								<p class="muted">{entry.data.venue}</p>
								<p>{entry.data.summary}</p>
								<p class="muted">{entry.data.authors.join(', ')}</p>
							</div>
							<div class="pub-links">
								{entry.data.links.map((link) => <a class="text-link" href={link.href}>{link.label}</a>)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</main>
</BaseLayout>

<style>
	.pub-card {
		padding: 1.25rem;
	}

	.pub-meta,
	.pub-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
</style>
