---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getSiteConfig } from '../lib/content';

const locale = 'en' as const;
const site = await getSiteConfig(locale);
const entries = (await getCollection('publications', ({ data }) => data.lang === locale)).sort((a, b) => {
	if (a.data.themeOrder !== b.data.themeOrder) return a.data.themeOrder - b.data.themeOrder;
	if (a.data.year !== b.data.year) return b.data.year - a.data.year;
	return b.data.order - a.data.order;
});

type PublicationGroup = {
	key: string;
	label: string;
	themeOrder: number;
	entries: typeof entries;
};

const groupedEntries = entries.reduce((map, entry) => {
	const existing = map.get(entry.data.themeKey);
	if (existing) {
		existing.entries.push(entry);
	} else {
		map.set(entry.data.themeKey, {
			key: entry.data.themeKey,
			label: entry.data.themeLabel,
			themeOrder: entry.data.themeOrder,
			entries: [entry],
		});
	}
	return map;
}, new Map<string, PublicationGroup>());

const groups = Array.from(groupedEntries.values()).sort((a, b) => a.themeOrder - b.themeOrder);
---

<BaseLayout locale={locale} alternatePath="/zh/publications/" title={`Publications | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading eyebrow="Publications" title="Publications" intro="Grouped by research direction." />

		<div class="stack gap-10">
			{
				groups.map((group) => (
					<section class="stack gap-6">
						<div class="theme-head">
							<span class="meta-chip warm">{group.label}</span>
						</div>

						<div class="stack gap-6">
							{group.entries.map((entry) => (
								<article class="surface-card pub-card">
									<div class="stack gap-4">
										<div class="pub-meta">
											<span class="meta-chip warm">{entry.data.type}</span>
											<span class="meta-chip">{String(entry.data.year)}</span>
										</div>
										<div class="stack gap-2">
											<h3>{entry.data.title}</h3>
											<p class="muted">{entry.data.venue}</p>
											<p class="muted">{entry.data.authors.join(', ')}</p>
										</div>
										<div class="pub-links">
											{entry.data.links.map((link) => <a class="text-link" href={link.href}>{link.label}</a>)}
										</div>
									</div>
								</article>
							))}
						</div>
					</section>
				))
			}
		</div>
	</main>
</BaseLayout>

<style>
	.pub-card {
		padding: 1.25rem;
	}

	.pub-meta,
	.pub-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
</style>
