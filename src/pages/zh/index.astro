---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import TimelineCard from '../../components/TimelineCard.astro';
import { getSiteConfig } from '../../lib/content';
import { localizePath } from '../../lib/site';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);

const projects = (await getCollection('projects', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const featuredProjects = projects.filter((project) =>
	site.featuredProjects.includes(project.data.translationKey),
);
const timeline = (await getCollection('timeline', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const posts = (await getCollection('blog', ({ data }) => data.lang === locale && !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const manuals = (await getCollection('manuals', ({ data }) => data.lang === locale)).sort(
	(a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);

const formatDate = (date: Date) =>
	date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	locale={locale}
	alternatePath="/"
	title={`${site.name} | ${site.title}`}
	description={site.tagline}
>
	<main class="wrapper page-main stack gap-20">
		<section class="hero-grid">
			<div class="stack gap-8">
				<div class="stack gap-4">
					<span class="eyebrow">Power Electronics Research</span>
					<h1>{site.hero.headline}</h1>
					<p class="hero-summary">{site.hero.subheadline}</p>
				</div>

				<ul class="tag-list">
					{site.hero.keywords.map((keyword) => <li class="tag">{keyword}</li>)}
				</ul>

				<div class="hero-meta">
					<div>
						<span class="meta-label">身份</span>
						<p>{site.title}</p>
					</div>
					<div>
						<span class="meta-label">所在地</span>
						<p>{site.location}</p>
					</div>
				</div>

				<div class="cta-row">
					<a class="button-link" href={localizePath(locale, 'current-focus')}>查看当前研究</a>
					<a class="button-link secondary" href={localizePath(locale, 'timeline')}>查看时间线</a>
				</div>
			</div>

			<div class="surface-card hero-panel">
				<div class="hero-panel-head">
					<p class="mono">RESEARCH SIGNAL</p>
					<p>30 秒概览</p>
				</div>
				<div class="wave-grid">
					<div class="wave wave-a" />
					<div class="wave wave-b" />
					<div class="wave wave-c" />
				</div>
				<div class="stats-grid">
					{
						site.hero.quickFacts.map((fact) => (
							<div class="stat-card">
								<span class="mono muted">{fact.label}</span>
								<h3>{fact.value}</h3>
								<p>{fact.detail}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Current Focus"
				title="我现在在研究什么"
				intro="这个区域的目标很明确：第一次访问的人应该能在很短时间内理解你的主研究问题、意义，以及实验室里正在推进的工作。"
			/>
			<div class="cards-grid three">
				<div class="surface-card info-card">
					<span class="meta-chip warm">研究主题</span>
					<p>{site.currentFocus.theme}</p>
				</div>
				<div class="surface-card info-card">
					<span class="meta-chip">为什么重要</span>
					<p>{site.currentFocus.importance}</p>
				</div>
				<div class="surface-card info-card">
					<span class="meta-chip">当前进展</span>
					<p>{site.currentFocus.now}</p>
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Featured Projects"
				title="最能代表当前方向的项目"
				intro="这些项目共同体现了平台化、验证流程和工程复用这条主线。"
			/>
			<div class="cards-grid three">
				{featuredProjects.map((project) => <ProjectCard project={project} locale={locale} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Journey"
				title="从基础积累到博士阶段的平台化研究"
				intro="用一条简洁时间线回看从本科到博士的能力积累与研究重点变化。"
			/>
			<div class="stack gap-6">
				{timeline.map((entry) => <TimelineCard entry={entry} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Writing and Manuals"
				title="思考、记录与实验手册"
				intro="博客用于记录观点和研究思考，手册用于沉淀可执行、可复用的实验与软硬件操作流程。"
			/>
			<div class="cards-grid two">
				<div class="stack gap-4">
					<h3>最新文章</h3>
					{
						posts.slice(0, 2).map((post) => (
							<EntryCard
								title={post.data.title}
								summary={post.data.summary}
								meta={formatDate(post.data.date)}
								tags={post.data.tags}
								href={localizePath(locale, `blog/${post.data.routeSlug}`)}
								ctaLabel="继续阅读"
							/>
						))
					}
				</div>
				<div class="stack gap-4">
					<h3>操作手册</h3>
					{
						manuals.slice(0, 2).map((manual) => (
							<EntryCard
								title={manual.data.title}
								summary={manual.data.summary}
								meta={`${manual.data.tool_or_platform} · ${formatDate(manual.data.updatedAt)}`}
								tags={manual.data.tags}
								href={localizePath(locale, `manuals/${manual.data.routeSlug}`)}
								ctaLabel="打开手册"
							/>
						))
					}
				</div>
			</div>
		</section>

		<section class="surface-card contact-panel">
			<div class="stack gap-4">
				<span class="eyebrow">Contact</span>
				<h2>{site.contact.title}</h2>
				<p class="lede">{site.contact.text}</p>
			</div>
			<div class="cta-row">
				<a class="button-link" href={`mailto:${site.email}`}>发送邮件</a>
				<a class="button-link secondary" href={localizePath(locale, 'cv')}>查看简历</a>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.hero-grid {
		display: grid;
		gap: 1.5rem;
	}

	.hero-summary {
		font-size: var(--text-lg);
		color: var(--text-muted);
		max-width: 42rem;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.meta-label {
		display: block;
		font-family: var(--font-code);
		font-size: var(--text-sm);
		color: var(--accent-alt);
		margin-bottom: 0.25rem;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.hero-panel {
		padding: 1.4rem;
		display: grid;
		gap: 1.25rem;
	}

	.hero-panel-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		color: var(--text-muted);
	}

	.wave-grid {
		display: grid;
		gap: 0.85rem;
		padding: 1rem 0;
	}

	.wave {
		height: 4.5rem;
		border-radius: 999rem;
		background-size: 220% 100%;
		animation: drift 9s linear infinite;
	}

	.wave-a {
		background:
			radial-gradient(circle at left, rgba(23, 196, 201, 0.45), transparent 28%),
			linear-gradient(90deg, rgba(23, 196, 201, 0.08), rgba(23, 196, 201, 0.3), transparent);
	}

	.wave-b {
		background:
			radial-gradient(circle at 20% 50%, rgba(221, 122, 50, 0.4), transparent 24%),
			linear-gradient(90deg, transparent, rgba(221, 122, 50, 0.3), rgba(23, 196, 201, 0.16));
		animation-duration: 12s;
	}

	.wave-c {
		background:
			radial-gradient(circle at 60% 50%, rgba(23, 196, 201, 0.35), transparent 18%),
			linear-gradient(90deg, rgba(23, 196, 201, 0.24), transparent, rgba(221, 122, 50, 0.22));
		animation-duration: 10s;
	}

	.stat-card,
	.info-card,
	.contact-panel {
		padding: 1.25rem;
	}

	.contact-panel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@keyframes drift {
		from {
			background-position: 0% 50%;
		}
		to {
			background-position: 200% 50%;
		}
	}

	@media (min-width: 62em) {
		.hero-grid {
			grid-template-columns: 1.3fr 0.9fr;
			align-items: center;
		}

		.contact-panel {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
