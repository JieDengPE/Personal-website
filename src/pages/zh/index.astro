---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import TimelineCard from '../../components/TimelineCard.astro';
import { getSiteConfig } from '../../lib/content';
import { localizePath } from '../../lib/site';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);

const projects = (await getCollection('projects', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const featuredProjects = projects.filter((project) =>
	site.featuredProjects.includes(project.data.translationKey),
);
const timeline = (await getCollection('timeline', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const posts = (await getCollection('blog', ({ data }) => data.lang === locale && !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const manuals = (await getCollection('manuals', ({ data }) => data.lang === locale)).sort(
	(a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);

const formatDate = (date: Date) =>
	date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	locale={locale}
	alternatePath="/"
	title={`${site.name} | ${site.title}`}
	description={site.tagline}
>
	<main class="wrapper page-main stack gap-20">
		<section class="home-hero">
			<div class="hero-copy stack gap-8">
				<div class="stack gap-4">
					<span class="eyebrow">Power Electronics / Medium Voltage</span>
					<h1>{site.hero.headline}</h1>
					<p class="hero-summary">{site.hero.subheadline}</p>
				</div>

				<ul class="tag-list">
					{site.hero.keywords.map((keyword) => <li class="tag">{keyword}</li>)}
				</ul>

				<div class="hero-actions">
					<a class="button-link" href={localizePath(locale, 'current-focus')}>查看当前研究</a>
					<a class="button-link secondary" href={localizePath(locale, 'timeline')}>查看时间线</a>
				</div>

				<div class="surface-card profile-band">
					<div class="profile-item">
						<span class="mono">身份</span>
						<p>{site.title}</p>
					</div>
					<div class="profile-item">
						<span class="mono">所在</span>
						<p>{site.location}</p>
					</div>
					<div class="profile-item">
						<span class="mono">联系</span>
						<p>{site.email}</p>
					</div>
				</div>
			</div>

			<div class="surface-card hero-panel">
				<div class="panel-head">
					<div class="stack gap-2">
						<p class="mono muted">30-SECOND BRIEF</p>
						<h2>研究速览</h2>
					</div>
					<span class="meta-chip warm">当前进行中</span>
				</div>

				<div class="signal-list">
					<article class="signal-item">
						<span class="signal-label">Who</span>
						<p>{site.title}，现于亚利桑那州立大学开展研究。</p>
					</article>
					<article class="signal-item">
						<span class="signal-label">What</span>
						<p>{site.currentFocus.theme}</p>
					</article>
					<article class="signal-item">
						<span class="signal-label">Why</span>
						<p>{site.currentFocus.importance}</p>
					</article>
					<article class="signal-item">
						<span class="signal-label">Next</span>
						<p>{site.currentFocus.now}</p>
					</article>
				</div>

				<div class="quick-grid">
					{
						site.hero.quickFacts.map((fact) => (
							<div class="quick-card">
								<span class="mono muted">{fact.label}</span>
								<h3>{fact.value}</h3>
								<p>{fact.detail}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Current Focus"
				title="一眼看懂我现在在做什么"
				intro="首页的目标很明确：让第一次访问的人能迅速理解你是谁、你在研究什么、为什么重要，以及接下来应该点开哪里。"
			/>
			<div class="cards-grid three">
				<div class="surface-card mini-card">
					<span class="meta-chip warm">研究主题</span>
					<p>{site.currentFocus.theme}</p>
				</div>
				<div class="surface-card mini-card">
					<span class="meta-chip">研究意义</span>
					<p>{site.currentFocus.importance}</p>
				</div>
				<div class="surface-card mini-card">
					<span class="meta-chip">当前主线</span>
					<p>{site.currentFocus.projects.map((project) => project.title).join(' / ')}</p>
				</div>
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Featured Projects"
				title="最能代表当前研究方向的项目"
				intro="这些项目基本定义了我目前理解中压电力电子系统的几个关键切面。"
			/>
			<div class="cards-grid three">
				{featuredProjects.map((project) => <ProjectCard project={project} locale={locale} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Journey"
				title="从硬件基础到中压系统研究的时间线"
				intro="这里简洁地呈现了本科阶段的工程训练、硕士阶段的研究深化，以及博士阶段正在推进的系统级方向。"
			/>
			<div class="stack gap-6">
				{timeline.map((entry) => <TimelineCard entry={entry} />)}
			</div>
		</section>

		<section class="page-section stack gap-8">
			<SectionHeading
				eyebrow="Writing and Manuals"
				title="想法记录与可复用的实验文档"
				intro="博客更偏思考、技术记录和阶段总结；手册更偏操作流程、实验步骤和能直接复用的文档资产。"
			/>
			<div class="cards-grid two">
				<div class="entry-column stack gap-4">
					<h3>最新文章</h3>
					{
						posts.slice(0, 2).map((post) => (
							<EntryCard
								title={post.data.title}
								summary={post.data.summary}
								meta={formatDate(post.data.date)}
								tags={post.data.tags}
								href={localizePath(locale, `blog/${post.data.routeSlug}`)}
								ctaLabel="继续阅读"
							/>
						))
					}
				</div>
				<div class="entry-column stack gap-4">
					<h3>实验手册</h3>
					{
						manuals.slice(0, 2).map((manual) => (
							<EntryCard
								title={manual.data.title}
								summary={manual.data.summary}
								meta={`${manual.data.tool_or_platform} · ${formatDate(manual.data.updatedAt)}`}
								tags={manual.data.tags}
								href={localizePath(locale, `manuals/${manual.data.routeSlug}`)}
								ctaLabel="打开手册"
							/>
						))
					}
				</div>
			</div>
		</section>

		<section class="surface-card contact-panel">
			<div class="stack gap-4">
				<span class="eyebrow">Contact</span>
				<h2>{site.contact.title}</h2>
				<p class="lede">{site.contact.text}</p>
			</div>
			<div class="hero-actions">
				<a class="button-link" href={`mailto:${site.email}`}>发送邮件</a>
				<a class="button-link secondary" href={localizePath(locale, 'cv')}>查看简历</a>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-hero {
		display: grid;
		gap: 1.5rem;
		align-items: start;
	}

	.hero-summary {
		max-width: 46rem;
		font-size: var(--text-lg);
		color: var(--text-body);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.profile-band,
	.hero-panel,
	.mini-card,
	.contact-panel {
		padding: 1.45rem;
	}

	.profile-band {
		display: grid;
		gap: 1rem;
	}

	.profile-item span,
	.signal-label {
		color: var(--accent-cyan);
		font-size: var(--text-sm);
		letter-spacing: 0.14em;
	}

	.profile-item p {
		margin-top: 0.35rem;
	}

	.hero-panel {
		display: grid;
		gap: 1.15rem;
		background:
			radial-gradient(circle at top right, rgba(70, 182, 200, 0.12), transparent 28%),
			radial-gradient(circle at left bottom, rgba(215, 121, 57, 0.12), transparent 30%),
			var(--gradient-panel);
	}

	.panel-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.signal-list,
	.quick-grid {
		display: grid;
		gap: 0.85rem;
	}

	.signal-item,
	.quick-card {
		padding: 1rem;
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(125, 148, 176, 0.12);
	}

	.signal-item p {
		margin-top: 0.45rem;
		color: var(--text-body);
	}

	.quick-card h3 {
		margin-top: 0.5rem;
		font-size: 1.35rem;
	}

	.quick-card p,
	.mini-card p {
		margin-top: 0.6rem;
		color: var(--text-muted);
	}

	.entry-column h3 {
		font-size: 1.35rem;
	}

	.contact-panel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (min-width: 48em) {
		.profile-band {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.quick-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 68em) {
		.home-hero {
			grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.92fr);
		}

		.contact-panel {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
