---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import { getSiteConfig } from '../../../lib/content';
import { localizePath } from '../../../lib/site';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const manuals = (await getCollection('manuals', ({ data }) => data.lang === locale)).sort(
	(a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);
const formatDate = (date: Date) =>
	date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout locale={locale} alternatePath="/manuals/" title={`手册 | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Manuals"
			title="可复用的软硬件操作手册"
			intro="这里专门放面向执行的内容，例如实验上电流程、调试步骤、平台搭建说明以及常见问题排查。"
		/>
		<div class="cards-grid two">
			{
				manuals.map((manual) => (
					<EntryCard
						title={manual.data.title}
						summary={manual.data.summary}
						meta={`${manual.data.tool_or_platform} · ${formatDate(manual.data.updatedAt)}`}
						tags={manual.data.tags}
						href={localizePath(locale, `manuals/${manual.data.routeSlug}`)}
						ctaLabel="打开手册"
					/>
				))
			}
		</div>
	</main>
</BaseLayout>
