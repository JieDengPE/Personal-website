---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSiteConfig } from '../../../lib/content';
import { localizePath } from '../../../lib/site';

interface Props {
	entry: CollectionEntry<'projects'>;
}

export async function getStaticPaths() {
	const entries = await getCollection('projects', ({ data }) => data.lang === 'zh');
	return entries.map((entry) => ({
		params: { slug: entry.data.routeSlug },
		props: { entry },
	}));
}

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const { entry } = Astro.props;
const { Content } = await render(entry);
const translation = (
	await getCollection('projects', ({ data }) => data.lang === 'en' && data.translationKey === entry.data.translationKey)
)[0];
const publications = (await getCollection('publications', ({ data }) => data.lang === locale)).filter((publication) =>
	entry.data.relatedPublications.includes(publication.data.translationKey),
);
const statusLabel = entry.data.status === 'completed' ? '已完成' : entry.data.status === 'ongoing' ? '持续推进' : '进行中';
---

<BaseLayout
	locale={locale}
	alternatePath={translation ? `/projects/${translation.data.routeSlug}/` : '/projects/'}
	title={`${entry.data.title} | ${site.name}`}
	description={entry.data.summary}
>
	<main class="wrapper page-main stack gap-10">
		<a class="text-link" href={localizePath('zh', 'projects')}>返回项目页</a>
		<section class="surface-card detail-card stack gap-6">
			<div class="stack gap-4">
				<div class="tag-list">
					<span class="meta-chip warm">{statusLabel}</span>
					<span class="meta-chip">{entry.data.period}</span>
					<span class="meta-chip">{entry.data.domain}</span>
				</div>
				<h1>{entry.data.title}</h1>
				<p class="lede">{entry.data.summary}</p>
				<ul class="tag-list">
					{entry.data.stack.map((item) => <li class="tag">{item}</li>)}
				</ul>
			</div>
			<div class="prose"><Content /></div>
			<div class="stack gap-4">
				<h3>重点内容</h3>
				<ul class="focus-list">
					{entry.data.highlights.map((highlight) => <li>{highlight}</li>)}
				</ul>
			</div>

			{
				publications.length > 0 && (
					<div class="stack gap-4 publication-block">
						<h3>相关论文</h3>
						<ul class="publication-list">
							{publications.map((publication) => (
								<li>
									<strong>{publication.data.title}</strong>
									<p>{`${publication.data.venue} · ${publication.data.year} · ${publication.data.type}`}</p>
									<div class="tag-list">
										{publication.data.links.map((link) => (
											<a class="text-link" href={link.href}>
												{link.label}
											</a>
										))}
									</div>
								</li>
							))}
						</ul>
					</div>
				)
			}

			{
				entry.data.links.length > 0 && (
					<div class="tag-list">
						{entry.data.links.map((link) => <a class="text-link" href={link.href}>{link.label}</a>)}
					</div>
				)
			}
		</section>
	</main>
</BaseLayout>

<style>
	.detail-card {
		padding: 1.4rem;
	}

	.focus-list,
	.publication-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.55rem;
	}

	.publication-list p {
		color: var(--text-muted);
		margin-top: 0.25rem;
	}

	.publication-block {
		padding-top: 0.5rem;
		border-top: 1px solid rgba(125, 148, 176, 0.12);
	}
</style>
