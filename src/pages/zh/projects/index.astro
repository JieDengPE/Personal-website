---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import { getSiteConfig } from '../../../lib/content';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const projects = (await getCollection('projects', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<BaseLayout locale={locale} alternatePath="/projects/" title={`项目 | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Projects"
			title="科研项目、实验平台与方向分支"
			intro="这里汇总了当前研究方向中的关键项目，包括中压变换器、辅助电源、功率模块、绝缘实验平台以及 AI 辅助设计探索。"
		/>
		<div class="cards-grid three">
			{projects.map((project) => <ProjectCard project={project} locale={locale} />)}
		</div>
	</main>
</BaseLayout>
