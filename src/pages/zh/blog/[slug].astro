---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localizePath } from '../../../lib/site';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const entries = await getCollection('blog', ({ data }) => data.lang === 'zh' && !data.draft);
	return entries.map((entry) => ({
		params: { slug: entry.data.routeSlug },
		props: { entry },
	}));
}

const locale = 'zh' as const;
const { entry } = Astro.props;
const { Content } = await render(entry);
const translation = (
	await getCollection('blog', ({ data }) => data.lang === 'en' && data.translationKey === entry.data.translationKey)
)[0];
const formatDate = entry.data.date.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout
	locale={locale}
	alternatePath={translation ? `/blog/${translation.data.routeSlug}/` : '/blog/'}
	title={entry.data.title}
	description={entry.data.summary}
>
	<main class="wrapper page-main stack gap-10">
		<a class="text-link" href={localizePath('zh', 'blog')}>返回博客页</a>
		<article class="surface-card detail-card stack gap-6">
			<div class="stack gap-4">
				<p class="mono muted">{formatDate}</p>
				<h1>{entry.data.title}</h1>
				<p class="lede">{entry.data.summary}</p>
				<ul class="tag-list">
					{entry.data.tags.map((tag) => <li class="tag">{tag}</li>)}
				</ul>
			</div>
			<div class="prose"><Content /></div>
		</article>
	</main>
</BaseLayout>

<style>
	.detail-card {
		padding: 1.4rem;
	}
</style>
