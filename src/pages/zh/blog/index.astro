---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import { getSiteConfig } from '../../../lib/content';
import { localizePath } from '../../../lib/site';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const posts = (await getCollection('blog', ({ data }) => data.lang === locale && !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const formatDate = (date: Date) =>
	date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout locale={locale} alternatePath="/blog/" title={`博客 | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Blog"
			title="研究思考、技术记录与阶段总结"
			intro="这里预留给观点、研究判断、阅读笔记和简短的技术思考，而不是严格的操作型文档。"
		/>
		{
			posts.length > 0 ? (
				<div class="cards-grid two">
					{posts.map((post) => (
						<EntryCard
							title={post.data.title}
							summary={post.data.summary}
							meta={formatDate(post.data.date)}
							tags={post.data.tags}
							href={localizePath(locale, `blog/${post.data.routeSlug}`)}
							ctaLabel="继续阅读"
						/>
					))}
				</div>
			) : (
				<section class="surface-card empty-state stack gap-4">
					<span class="meta-chip warm">还没有文章</span>
					<h2>博客内容尚未开始写</h2>
					<p class="lede">
						这一页目前刻意保持为空。以后可以在这里记录研究想法、阅读笔记和阶段性的技术反思。
					</p>
				</section>
			)
		}
	</main>
</BaseLayout>

<style>
	.empty-state {
		padding: 1.5rem;
		max-width: 48rem;
	}
</style>
