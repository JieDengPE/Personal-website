---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getSiteConfig } from '../../lib/content';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
---

<BaseLayout locale={locale} alternatePath="/skills/" title={`技能 | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Skills"
			title="按工程系统组织的能力结构"
			intro="这里不是简单罗列软件或标签，而是按照它们如何服务于变换器设计、控制实现、实验验证与系统研究来组织能力。"
		/>
		<div class="cards-grid three">
			{
				site.skillGroups.map((group) => (
					<article class="surface-card skill-card">
						<div class="stack gap-4">
							<h3>{group.title}</h3>
							<p>{group.description}</p>
							<ul class="focus-list">
								{group.items.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					</article>
				))
			}
		</div>
	</main>
</BaseLayout>

<style>
	.skill-card {
		padding: 1.25rem;
	}

	.focus-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.55rem;
	}
</style>
