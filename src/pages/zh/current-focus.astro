---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getSiteConfig } from '../../lib/content';
import { localizePath } from '../../lib/site';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const activeProjects = (await getCollection('projects', ({ data }) => data.lang === locale))
	.filter((project) => project.data.status !== 'completed')
	.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
	locale={locale}
	alternatePath="/current-focus/"
	title={`当前研究 | ${site.name}`}
	description={site.currentFocus.importance}
>
	<main class="wrapper page-main stack gap-16">
		<SectionHeading
			eyebrow="Current Focus"
			title="我现在正在推进的项目"
			intro="这一页只展示仍在进行中的研究项目，也就是那些还在持续搭建、验证、推进和收敛的方向。"
		/>

		<section class="surface-card focus-overview">
			<div class="stack gap-4">
				<span class="meta-chip warm">研究主题</span>
				<h2>{site.currentFocus.theme}</h2>
				<p class="lede">{site.currentFocus.now}</p>
			</div>
			<ul class="tag-list">
				{site.researchAreas.map((area) => <li class="tag">{area}</li>)}
			</ul>
		</section>

		<section class="cards-grid two">
			{
				activeProjects.map((project) => (
					<article class="surface-card project-brief stack gap-4">
						<div class="project-brief-meta">
							<span class="meta-chip warm">
								{project.data.status === 'ongoing' ? '持续推进' : '进行中'}
							</span>
							<span class="meta-chip">{project.data.period}</span>
						</div>
						<div class="stack gap-2">
							<h3>{project.data.title}</h3>
							<p>{project.data.summary}</p>
						</div>
						<ul class="tag-list">
							{project.data.keywords.slice(0, 4).map((keyword) => <li class="tag">{keyword}</li>)}
						</ul>
						<a class="text-link" href={localizePath(locale, `projects/${project.data.routeSlug}`)}>
							查看项目详情
						</a>
					</article>
				))
			}
		</section>

		<section class="cards-grid two">
			<article class="surface-card focus-card stack gap-4">
				<span class="meta-chip">为什么重要</span>
				<p>{site.currentFocus.importance}</p>
			</article>
			<article class="surface-card focus-card stack gap-4">
				<span class="meta-chip">近期目标</span>
				<ul class="focus-list">
					{site.currentFocus.goals.map((item) => <li>{item}</li>)}
				</ul>
			</article>
		</section>
	</main>
</BaseLayout>

<style>
	.focus-overview,
	.project-brief,
	.focus-card {
		padding: 1.45rem;
	}

	.project-brief {
		min-height: 100%;
	}

	.project-brief p,
	.focus-card p {
		color: var(--text-muted);
	}

	.project-brief-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		justify-content: flex-start;
	}

	.focus-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.6rem;
	}
</style>
