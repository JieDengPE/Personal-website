---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { getSiteConfig } from '../../lib/content';

const locale = 'zh' as const;
const site = await getSiteConfig(locale);
const projects = (await getCollection('projects', ({ data }) => data.lang === locale)).filter(
	(project) => project.data.status !== 'completed',
);
---

<BaseLayout locale={locale} alternatePath="/current-focus/" title={`当前研究 | ${site.name}`}>
	<main class="wrapper page-main stack gap-12">
		<SectionHeading
			eyebrow="Current Focus"
			title="我现在在研究什么，以及它为什么重要"
			intro="这页的目的很直接：先回答当前主研究问题是什么，再说明它如何被落到真实系统和实验平台中。"
		/>

		<section class="cards-grid three">
			<div class="surface-card focus-card">
				<span class="meta-chip warm">研究主题</span>
				<p>{site.currentFocus.theme}</p>
			</div>
			<div class="surface-card focus-card">
				<span class="meta-chip">研究意义</span>
				<p>{site.currentFocus.importance}</p>
			</div>
			<div class="surface-card focus-card">
				<span class="meta-chip">当前进展</span>
				<p>{site.currentFocus.now}</p>
			</div>
		</section>

		<section class="stack gap-6">
			<SectionHeading eyebrow="Active Projects" title="正在推进的项目主线" />
			<div class="cards-grid three">
				{projects.slice(0, 3).map((project) => <ProjectCard project={project} locale={locale} />)}
			</div>
		</section>

		<section class="cards-grid two">
			<div class="surface-card focus-card stack gap-4">
				<h3>方法与平台</h3>
				<ul class="focus-list">
					{site.currentFocus.methods.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<div class="surface-card focus-card stack gap-4">
				<h3>近期目标</h3>
				<ul class="focus-list">
					{site.currentFocus.goals.map((item) => <li>{item}</li>)}
				</ul>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.focus-card {
		padding: 1.25rem;
	}

	.focus-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.6rem;
	}
</style>
