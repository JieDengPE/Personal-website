---
import Footer from '../components/Footer.astro';
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import { getSiteConfig } from '../lib/content';
import type { Locale } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
	locale: Locale;
	alternatePath?: string;
	currentPath?: string;
}

const { title, description, locale, alternatePath, currentPath = Astro.url.pathname } = Astro.props;
const site = await getSiteConfig('en');
---

<html lang={locale}>
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<div class="site-shell">
			<div class="site-topology" aria-hidden="true">
				<div class="topology-layer topology-layer-grid" />
				<div class="topology-layer topology-layer-flow" />
				<div class="topology-layer topology-layer-nodes" />
				<div class="topology-layer topology-layer-glow" />
			</div>
			<Nav
				locale={locale}
				currentPath={currentPath}
				alternatePath={alternatePath}
				siteName={site.name}
			/>
			<slot />
			<Footer locale={locale} siteName={site.name} socialLinks={site.socialLinks} />
		</div>
	</body>
</html>
