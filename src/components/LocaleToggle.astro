---
import type { Locale } from '../lib/site';

interface Props {
	locale: Locale;
	currentPath: string;
	alternatePath?: string;
}

const { locale, currentPath, alternatePath } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : `/${import.meta.env.BASE_URL.replace(/^\/|\/$/g, '')}`;
const withBase = (path: string) => (path.startsWith(base) ? path : `${base}${path}`.replace(/\/{2,}/g, '/'));
const enPath = withBase(locale === 'en' ? currentPath : alternatePath ?? '/');
const zhPath = withBase(locale === 'zh' ? currentPath : alternatePath ?? '/zh/');
---

<div class="locale-toggle" aria-label="Language switch">
	<a href={enPath} aria-current={locale === 'en' ? 'page' : null}>EN</a>
	<a href={zhPath} aria-current={locale === 'zh' ? 'page' : null}>中文</a>
</div>

<style>
	.locale-toggle {
		display: inline-flex;
		padding: 0.22rem;
		border-radius: 999rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid var(--surface-border);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
	}

	.locale-toggle a {
		padding: 0.48rem 0.86rem;
		border-radius: 999rem;
		text-decoration: none;
		color: var(--text-muted);
		font-family: var(--font-code);
		font-size: var(--text-sm);
		transition:
			background-color var(--theme-transition),
			color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.locale-toggle a[aria-current='page'] {
		background: linear-gradient(135deg, rgba(217, 117, 45, 0.22), rgba(56, 175, 199, 0.18));
		color: var(--text-strong);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
	}
 </style>
