---
import Icon from './Icon.astro';
import LocaleToggle from './LocaleToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Locale } from '../lib/site';
import { isActivePath, localizedLabels, localizePath } from '../lib/site';

interface Props {
	locale: Locale;
	currentPath: string;
	alternatePath?: string;
	siteName: string;
}

const { locale, currentPath, alternatePath, siteName } = Astro.props;
const labels = localizedLabels[locale];
---

<nav class="wrapper nav-shell">
	<a href={localizePath(locale)} class="site-title">
		<span class="brand-mark">
			<Icon icon="terminal-window" color="var(--accent-regular)" size="1.6em" gradient />
		</span>
		<span class="brand-copy">
			<strong>{siteName}</strong>
			<small>{labels.brandRole}</small>
		</span>
	</a>

	<div class="nav-panel">
		<ul class="nav-items">
			{
				labels.navigation.map(({ label, segment }) => {
					const href = localizePath(locale, segment);
					return (
						<li>
							<a aria-current={isActivePath(currentPath, href) ? 'page' : null} class="link" href={href}>
								{label}
							</a>
						</li>
					);
				})
			}
		</ul>

		<div class="nav-tools">
			<LocaleToggle locale={locale} currentPath={currentPath} alternatePath={alternatePath} />
			<ThemeToggle />
		</div>
	</div>
</nav>

<style>
	.nav-shell {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-top: 1.25rem;
		padding-bottom: 2rem;
	}

	.site-title {
		display: flex;
		gap: 1rem;
		align-items: center;
		color: var(--gray-50);
		text-decoration: none;
	}

	.brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		inline-size: 3rem;
		block-size: 3rem;
		border-radius: 999rem;
		background: linear-gradient(160deg, rgba(239, 143, 72, 0.18), rgba(23, 196, 201, 0.08));
		border: 1px solid rgba(239, 143, 72, 0.24);
		box-shadow: var(--shadow-sm);
	}

	.brand-copy {
		display: grid;
		gap: 0.15rem;
	}

	.brand-copy strong {
		font-size: var(--text-md);
		font-family: var(--font-brand);
	}

	.brand-copy small {
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.nav-panel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1rem;
		border: 1px solid var(--surface-border);
		border-radius: 1.5rem;
		background: var(--surface-panel);
		backdrop-filter: blur(18px);
		box-shadow: var(--shadow-md);
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		font-size: var(--text-sm);
		line-height: 1.2;
		list-style: none;
		padding: 0;
	}

	.link {
		display: inline-block;
		color: var(--gray-400);
		text-decoration: none;
		padding: 0.5rem 0.85rem;
		border-radius: 999rem;
		transition:
			color var(--theme-transition),
			background-color var(--theme-transition),
			border-color var(--theme-transition);
	}

	.link[aria-current] {
		background: rgba(239, 143, 72, 0.14);
		border: 1px solid rgba(239, 143, 72, 0.28);
		color: var(--gray-50);
	}

	.link:hover,
	.link:focus-visible {
		color: var(--gray-50);
		background: rgba(23, 196, 201, 0.1);
	}

	.nav-tools {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		justify-content: space-between;
	}

	@media (min-width: 50em) {
		.nav-shell {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 2rem;
			padding-top: 2.25rem;
			padding-bottom: 2.5rem;
		}

		.nav-panel {
			flex: 1;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}

		.nav-items {
			max-width: 48rem;
		}

		.nav-tools {
			justify-content: flex-end;
		}
	}
</style>
