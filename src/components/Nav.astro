---
import Icon from './Icon.astro';
import LocaleToggle from './LocaleToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Locale } from '../lib/site';
import { isActivePath, localizedLabels, localizePath } from '../lib/site';

interface Props {
	locale: Locale;
	currentPath: string;
	alternatePath?: string;
	siteName: string;
}

const { locale, currentPath, alternatePath, siteName } = Astro.props;
const labels = localizedLabels[locale];
---

<nav class="wrapper nav-shell">
	<a href={localizePath(locale)} class="site-title">
		<span class="brand-mark">
			<Icon icon="terminal-window" color="var(--accent-copper)" size="1.55em" gradient />
		</span>
		<span class="brand-copy">
			<strong>{siteName}</strong>
			<small>{labels.brandRole}</small>
		</span>
	</a>

	<div class="nav-panel">
		<ul class="nav-items">
			{
				labels.navigation.map(({ label, segment }) => {
					const href = localizePath(locale, segment);
					return (
						<li>
							<a aria-current={isActivePath(currentPath, href) ? 'page' : null} class="link" href={href}>
								{label}
							</a>
						</li>
					);
				})
			}
		</ul>

		<div class="nav-tools">
			<LocaleToggle locale={locale} currentPath={currentPath} alternatePath={alternatePath} />
			<ThemeToggle />
		</div>
	</div>
</nav>

<style>
	.nav-shell {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		padding-top: 1.25rem;
		padding-bottom: 1.75rem;
	}

	.site-title {
		display: flex;
		gap: 0.9rem;
		align-items: center;
		color: var(--gray-50);
		text-decoration: none;
	}

	.brand-mark {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		inline-size: 2.85rem;
		block-size: 2.85rem;
		border-radius: 1rem;
		background:
			linear-gradient(155deg, rgba(215, 121, 57, 0.18), rgba(70, 182, 200, 0.08)),
			rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(215, 121, 57, 0.22);
		box-shadow: var(--shadow-sm);
	}

	.brand-mark::after {
		content: '';
		position: absolute;
		inset: auto 0.55rem 0.4rem auto;
		inline-size: 0.38rem;
		block-size: 0.38rem;
		border-radius: 999rem;
		background: var(--accent-cyan);
		box-shadow: 0 0 0.7rem rgba(70, 182, 200, 0.42);
	}

	.brand-copy {
		display: grid;
		gap: 0.1rem;
		min-width: 0;
	}

	.brand-copy strong {
		font-size: 1rem;
		font-family: var(--font-brand);
		line-height: 1.05;
	}

	.brand-copy small {
		color: var(--text-muted);
		font-size: 0.88rem;
	}

	.nav-panel {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		padding: 0.9rem;
		border: 1px solid var(--surface-border-strong);
		border-radius: 1.35rem;
		background:
			radial-gradient(circle at top right, rgba(70, 182, 200, 0.08), transparent 24%),
			radial-gradient(circle at left center, rgba(215, 121, 57, 0.08), transparent 28%),
			linear-gradient(180deg, rgba(14, 20, 31, 0.86), rgba(12, 18, 28, 0.8));
		backdrop-filter: blur(22px);
		box-shadow: var(--shadow-md);
		overflow: hidden;
	}

	.nav-panel::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(110deg, transparent 0 19%, rgba(70, 182, 200, 0.08) 19.3%, transparent 19.8%),
			linear-gradient(138deg, transparent 0 66%, rgba(215, 121, 57, 0.07) 66.3%, transparent 66.8%);
		opacity: 0.9;
		pointer-events: none;
	}

	.nav-items,
	.nav-tools {
		position: relative;
		z-index: 1;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		font-size: 0.95rem;
		line-height: 1.2;
		list-style: none;
		padding: 0;
	}

	.link {
		display: inline-block;
		color: var(--text-muted);
		text-decoration: none;
		padding: 0.45rem 0.74rem;
		border-radius: 999rem;
		border: 1px solid transparent;
		white-space: nowrap;
		transition:
			color var(--theme-transition),
			background-color var(--theme-transition),
			border-color var(--theme-transition);
	}

	.link[aria-current] {
		background: linear-gradient(135deg, rgba(215, 121, 57, 0.14), rgba(70, 182, 200, 0.08));
		border-color: rgba(215, 121, 57, 0.24);
		color: var(--text-strong);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.025);
	}

	.link:hover,
	.link:focus-visible {
		color: var(--text-strong);
		background: rgba(70, 182, 200, 0.08);
	}

	.nav-tools {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
		justify-content: flex-start;
	}

	@media (max-width: 37.99em) {
		.brand-copy small {
			display: none;
		}
	}

	@media (min-width: 50em) {
		.nav-shell {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: 1.75rem;
			padding-top: 1.85rem;
			padding-bottom: 2.2rem;
		}

		.nav-panel {
			flex: 1;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			padding-inline: 1rem;
		}

		.nav-items {
			max-width: 50rem;
		}

		.nav-tools {
			justify-content: flex-end;
		}
	}
</style>
