---
import type { HTMLAttributes } from 'astro/types';

interface Props {
	label: string;
	kind: 'brand' | 'monogram';
	color: string;
	svgPath?: string;
	monogram?: string;
}

const { color, kind, label, monogram, svgPath } = Astro.props;

const svgAttrs: HTMLAttributes<'svg'> = {
	viewBox: '0 0 24 24',
	role: 'img',
	'aria-label': label,
};
---

<div class="skill-badge" style={`--badge-color: ${color};`}>
	<div class:list={['badge-mark', kind === 'brand' ? 'is-brand' : 'is-monogram']} aria-hidden="true">
		{
			kind === 'brand' && svgPath ? (
				<svg {...svgAttrs}>
					<path d={svgPath} />
				</svg>
			) : (
				<span>{monogram}</span>
			)
		}
	</div>
	<span class="badge-label">{label}</span>
</div>

<style>
	.skill-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		min-height: 3.6rem;
		padding: 0.7rem 0.85rem;
		border-radius: 1rem;
		border: 1px solid rgba(125, 148, 176, 0.14);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
			rgba(255, 255, 255, 0.02);
	}

	.badge-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: none;
		inline-size: 2.35rem;
		block-size: 2.35rem;
		border-radius: 0.9rem;
		background: color-mix(in srgb, var(--badge-color) 18%, rgba(255, 255, 255, 0.03));
		border: 1px solid color-mix(in srgb, var(--badge-color) 44%, rgba(255, 255, 255, 0.1));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
		color: var(--badge-color);
	}

	.badge-mark svg {
		inline-size: 1.15rem;
		block-size: 1.15rem;
		fill: currentcolor;
	}

	.badge-mark span {
		font-family: var(--font-code);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.08em;
	}

	.badge-label {
		color: var(--text-body);
		font-weight: 600;
		line-height: 1.35;
	}

	html[lang='zh'] .badge-mark span {
		letter-spacing: 0.04em;
	}
</style>
