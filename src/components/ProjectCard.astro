---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../lib/site';
import { localizePath, localizedLabels } from '../lib/site';

interface Props {
	project: CollectionEntry<'projects'>;
	locale: Locale;
	relatedPublications?: CollectionEntry<'publications'>[];
}

const { project, locale, relatedPublications = [] } = Astro.props;
const labels = localizedLabels[locale];
const statusLabels = {
	en: { active: 'Active', ongoing: 'Ongoing', completed: 'Completed' },
	zh: { active: '进行中', ongoing: '持续推进', completed: '已完成' },
};
const publicationLabel = locale === 'en' ? 'Related publications' : '相关论文';
---

<article class="surface-card project-card">
	<div class="meta-row">
		<span class="meta-chip warm">{statusLabels[locale][project.data.status]}</span>
		<span class="meta-chip">{project.data.period}</span>
	</div>
	<div class="stack gap-4">
		<div class="stack gap-2">
			<p class="project-domain">{project.data.domain}</p>
			<h3>{project.data.title}</h3>
			<p class="project-summary">{project.data.summary}</p>
		</div>

		<ul class="tag-list">
			{project.data.keywords.slice(0, 4).map((keyword) => <li class="tag">{keyword}</li>)}
		</ul>

		<ul class="project-highlights">
			{project.data.highlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
		</ul>

		{
			relatedPublications.length > 0 && (
				<div class="project-publications stack gap-2">
					<p class="project-publications-label">{publicationLabel}</p>
					<ul class="project-publications-list">
						{relatedPublications.slice(0, 2).map((publication) => (
							<li>
								<strong>{publication.data.title}</strong>
								<span>{`${publication.data.venue} · ${publication.data.year}`}</span>
							</li>
						))}
					</ul>
				</div>
			)
		}

		<a class="text-link" href={localizePath(locale, `projects/${project.data.routeSlug}`)}>
			{labels.viewProject}
		</a>
	</div>
</article>

<style>
	.project-card {
		padding: 1.5rem;
		min-height: 100%;
	}

	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}

	.project-domain {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--accent-cyan);
		font-family: var(--font-code);
	}

	.project-summary {
		color: var(--text-muted);
	}

	.project-highlights {
		padding-left: 1.1rem;
		display: grid;
		gap: 0.6rem;
	}

	.project-highlights li {
		color: var(--text-muted);
	}

	.project-publications {
		padding-top: 0.15rem;
		border-top: 1px solid rgba(125, 148, 176, 0.12);
	}

	.project-publications-label {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent-copper);
		font-family: var(--font-code);
	}

	.project-publications-list {
		padding-left: 1rem;
		display: grid;
		gap: 0.55rem;
	}

	.project-publications-list li {
		color: var(--text-muted);
	}

	.project-publications-list strong,
	.project-publications-list span {
		display: block;
	}

	.project-publications-list strong {
		color: var(--text-strong);
		font-weight: 600;
	}

	.project-publications-list span {
		font-size: var(--text-sm);
	}
</style>
